#!/usr/bin/env bash
set -e

# Fix noexec mounts
if [[ -z "${APPIMAGE_EXTRACT_AND_RUN:-}" ]]; then
    export APPIMAGE_EXTRACT_AND_RUN=1
    exec "$APPIMAGE" "$@"
fi

HERE="$(dirname "$(readlink -f "$0")")"

CUSTOM_LIBRARY="$HERE/usr/lib/forcepoint-client"
BIN="$HERE/usr/bin/_forcepoint-client"

# Load config safely
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/forcepoint/fp.conf"
if [[ -f "$CONFIG_FILE" ]]; then
    set +u
    source "$CONFIG_FILE"
    set -u
fi

echo "Running Forcepoint VPN..."

# 🔥 CRITICAL: pass LD_LIBRARY_PATH inside sudo
exec sudo LD_LIBRARY_PATH="$CUSTOM_LIBRARY" "$BIN" "$@"